FROM golang:1.24 AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /out/stserver ./cmd/stserver

FROM gcr.io/distroless/base-debian12

WORKDIR /app

COPY --from=builder /out/stserver /app/stserver

EXPOSE 50051

ENTRYPOINT ["/app/stserver", "serve"]
